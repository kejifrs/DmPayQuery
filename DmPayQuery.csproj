<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>myicon.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <Company> </Company>
    <Product>哆咪消费一键查询工具</Product>
    <AssemblyVersion>3.2.0.0</AssemblyVersion>
    <FileVersion>3.2.0.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Embed the icon into the assembly so it is available as a WPF resource -->
    <Resource Include="myicon.ico" />
    <None Include="version.rc">
      <SubType>Code</SubType>
    </None>
  </ItemGroup>

  <!-- Allow the SDK to include XAML files as Page so the XAML compiler
       generates the partial classes and InitializeComponent. Previously
       MainWindow.xaml was treated as a Resource which prevented the
       generated code and named element fields (like LogScrollViewer)
       from being produced. -->
  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.1" />
    <PackageReference Include="EPPlus" Version="8.5.0" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.5" />
  </ItemGroup>



</Project>
