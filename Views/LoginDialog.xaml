<Window x:Class="DmPayQuery.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统登录"
        SizeToContent="WidthAndHeight"
        MinWidth="360" MinHeight="300"
        MaxWidth="480" MaxHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei">

    <Border Background="#F5F5F5" CornerRadius="8" BorderBrush="#DDD" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
    <Border.Resources>
        <Style x:Key="TextInlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#1E88E5" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0D47A1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="#074a86" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E88E5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                BorderBrush="#1565C0"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#1E88E5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1E88E5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Border.Resources>

    <Grid Margin="30" Opacity="0">
        <Grid.Triggers> 
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)" From="0" To="1" Duration="0:0:0.25" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="系统登录" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"
                   LineHeight="15"
                   LineStackingStrategy="BlockLineHeight" />

        <StackPanel Grid.Row="1" Margin="0,10">
            <!-- 账号 (占位符 + 左侧图标 内嵌) -->
            <Grid Margin="0,0,0,8">
                <!-- single cell, overlay icon and placeholder over TextBox -->
                <TextBox x:Name="AccountTextBox" Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="30,0,8,0" VerticalContentAlignment="Center" FontSize="14" />
                <!-- left icon inside box -->
                <TextBlock Text="👤" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" IsHitTestVisible="False"/>
                <!-- placeholder -->
                <TextBlock Text="请输入账号" VerticalAlignment="Center" Foreground="#999" Margin="36,0,0,0" IsHitTestVisible="False" Opacity="0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=AccountTextBox}" Value="">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- 密码 (占位符 + 左侧图标，右侧明文切换内嵌) -->
            <Grid Margin="0,0,0,8">
                <PasswordBox x:Name="PasswordBox" Height="35" Padding="30,0,40,0" VerticalContentAlignment="Center" FontSize="14" />
                <TextBox x:Name="PasswordTextBox" Height="35" Padding="30,0,40,0" VerticalContentAlignment="Center" FontSize="14" Visibility="Collapsed" />
                <!-- left icon -->
                <TextBlock Text="🔒" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" IsHitTestVisible="False" />
                <!-- right toggle inside box -->
                <ToggleButton x:Name="ShowPasswordBtn" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Background="Transparent" BorderThickness="0" Content="👁" FontSize="14" Cursor="Hand" ToolTip="显示/隐藏密码"/>
                <!-- placeholder -->
                <TextBlock Text="请输入密码" VerticalAlignment="Center" Foreground="#999" Margin="36,0,40,0" IsHitTestVisible="False" Opacity="0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=PasswordTextBox}" Value="">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- 验证码 (占位符 + 左侧图标，右侧文本式按钮内嵌) -->
            <Grid>
                <TextBox x:Name="CodeTextBox" Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="30,0,90,0" VerticalContentAlignment="Center" FontSize="14" />
                <TextBlock Text="🔢" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" IsHitTestVisible="False" />
                <TextBlock Text="请输入验证码" VerticalAlignment="Center" Foreground="#999" Margin="36,0,90,0" IsHitTestVisible="False" Opacity="0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=CodeTextBox}" Value="">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- right inline text-button -->
                <Button Content="{Binding CountdownText}" Command="{Binding GetCodeCommand}" IsEnabled="{Binding CanGetCode}" Width="80" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Padding="6,0"
                        Style="{StaticResource TextInlineButtonStyle}" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,25,0,0">
            <Button Content="登录" Command="{Binding LoginCommand}" IsDefault="True" Margin="0,0,15,0" Cursor="Hand" Style="{StaticResource PrimaryButtonStyle}" />

            <Button Content="取消" IsCancel="True" Cursor="Hand" Style="{StaticResource SecondaryButtonStyle}" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
    </Border>
</Window>