<Window x:Class="DmPayQuery.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DmPayQuery"
        xmlns:models="clr-namespace:DmPayQuery.Models"
        xmlns:converters="clr-namespace:DmPayQuery.Converters"
        mc:Ignorable="d"
        Title="哆咪消费一键查询工具 v3.2.1"
        Icon="pack://application:,,,/DmPayQuery;component/myicon.ico"
        SizeToContent="WidthAndHeight"
        MaxWidth="1200" MaxHeight="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Microsoft YaHei">

    <Window.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DropShadowEffect x:Key="CardShadow"
                         ShadowDepth="2"
                         BlurRadius="8"
                         Opacity="0.2"
                         Color="Gray"/>

        <!-- Tab 标题样式 -->
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="#555"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1E88E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <!-- Tab 查询配置区 -->
            <RowDefinition Height="Auto"/>
            <!-- 文件选择 + 操作按钮 + 进度条 -->
            <RowDefinition Height="Auto"/>
            <!-- 运行日志 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             配置区：Tab 切换（消费查询 / 流水开厅实名查询）
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#fafafa"
                CornerRadius="8"
                Padding="20,15"
                Margin="0,0,0,12"
                Effect="{StaticResource CardShadow}">
            <StackPanel>

                <TabControl SelectedIndex="{Binding ActiveTabIndex}"
                            Background="Transparent"
                            BorderThickness="0,0,0,1"
                            BorderBrush="#E0E0E0"
                            Padding="0">

                    <!-- ─── Tab1：消费查询 ─── -->
                    <TabItem Header="💰 消费查询" Style="{StaticResource TabItemStyle}">
                        <StackPanel Margin="0,14,0,0">

                            <!-- 提示文字 -->
                            <TextBlock Text="📋 从表格读取「消费ID」或「消费UID」列"
                                       FontSize="12" Foreground="#888" Margin="0,0,0,10"/>

                            <!-- 查询模式 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="查询模式：" Width="90" VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#555" FontSize="14"/>
                                <RadioButton Content="ID查充值/送礼"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.IdRechargeOrGift}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="ID只查送礼"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.IdGiftOnly}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="UID查充值/送礼"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.UidRechargeOrGift}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <!-- 拍走时间（开始日期模式） -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <TextBlock Text="拍走时间：" Width="90" VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#555" FontSize="14"/>
                                <RadioButton Content="不调整默认"
                                             IsChecked="{Binding DateMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DateMode.Original}}"
                                             Margin="0,0,22,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="拍走时间前1天（防止0点填错）"
                                             IsChecked="{Binding DateMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DateMode.PreviousDay}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <!-- 截止时间策略 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="截止时间：" Width="90" VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#555" FontSize="14"/>
                                <RadioButton Content="最新"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Latest}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="7日"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Days7}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="15日"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Days15}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="30日"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Days30}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                        </StackPanel>
                    </TabItem>

                    <!-- ─── Tab2：流水/开厅日期/实名查询 ─── -->
                    <TabItem Header="📊 流水/开厅日期/实名查询" Style="{StaticResource TabItemStyle}">
                        <StackPanel Margin="0,14,0,0">

                            <!-- 提示文字 -->
                            <TextBlock Text="📋 从表格读取「消费ID」列（厅ID 或 主播ID，不限制长度）"
                                       FontSize="12" Foreground="#888" Margin="0,0,0,10"/>

                            <!-- 查询模式 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="查询模式：" Width="90" VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#555" FontSize="14"/>
                                <RadioButton Content="ID查厅流水&amp;开厅时间"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.RoomSerialAndCreateTime}}"
                                             Margin="0,0,22,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="ID查主播流水&amp;实名"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.AnchorSerialAndIdCard}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <!-- 自定义开始时间 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <TextBlock Text="开始时间：" Width="90" VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#555" FontSize="14"/>
                                <TextBox Text="{Binding CustomStartTime, UpdateSourceTrigger=PropertyChanged}"
                                         Width="200" Height="32"
                                         VerticalContentAlignment="Center"
                                         Padding="8,0"
                                         BorderBrush="#DDD"
                                         BorderThickness="1"
                                         Background="White"
                                         FontSize="13"
                                         FontFamily="Consolas"
                                         ToolTip="格式：yyyy-MM-dd HH:mm:ss"/>
                                <TextBlock Text="格式：yyyy-MM-dd HH:mm:ss" FontSize="11"
                                           Foreground="#AAA" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- 自定义截止时间 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="截止时间：" Width="90" VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#555" FontSize="14"/>
                                <TextBox Text="{Binding CustomEndTime, UpdateSourceTrigger=PropertyChanged}"
                                         Width="200" Height="32"
                                         VerticalContentAlignment="Center"
                                         Padding="8,0"
                                         BorderBrush="#DDD"
                                         BorderThickness="1"
                                         Background="White"
                                         FontSize="13"
                                         FontFamily="Consolas"
                                         ToolTip="格式：yyyy-MM-dd HH:mm:ss"/>
                                <TextBlock Text="格式：yyyy-MM-dd HH:mm:ss" FontSize="11"
                                           Foreground="#AAA" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             文件选择 + 操作按钮 + 进度条（公共区域）
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#fafafa"
                CornerRadius="8"
                Padding="20,15"
                Margin="0,0,0,12"
                Effect="{StaticResource CardShadow}">
            <StackPanel>

                <!-- 文件选择 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Excel文件：" Width="90" VerticalAlignment="Center"
                               FontWeight="Bold" Foreground="#555" FontSize="14"/>
                    <Button Content="选择文件"
                            Command="{Binding SelectFileCommand}"
                            Width="96" Height="34"
                            Background="White"
                            BorderBrush="#1E88E5"
                            BorderThickness="1"
                            Foreground="#1E88E5"
                            FontWeight="SemiBold"/>
                    <Grid Margin="10,0,0,0">
                        <TextBox x:Name="FilePathTextBox"
                                 Text="{Binding FilePath}"
                                 IsReadOnly="True"
                                 Width="340" Height="34"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 BorderBrush="#DDD"
                                 BorderThickness="1"
                                 Background="#FAFAFA"/>
                        <TextBlock Text="请选择待查询的Excel表文件"
                                   VerticalAlignment="Center"
                                   Foreground="#999"
                                   Margin="16,0,0,0"
                                   IsHitTestVisible="False"
                                   Opacity="0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=FilePathTextBox}" Value="">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button Content="🚀 一键查询"
                            Command="{Binding StartQueryCommand}"
                            IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBooleanConverter}}"
                            Width="140" Height="42"
                            Background="#1E88E5"
                            Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0"
                            Margin="0,0,18,0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#2196f3"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🗑️ 清空日志"
                            Command="{Binding ClearLogsCommand}"
                            Width="140" Height="42"
                            Background="#fafafa"
                            BorderBrush="#1E88E5"
                            BorderThickness="2"
                            Foreground="#1E88E5"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>

                <!-- 进度条 -->
                <ProgressBar Value="{Binding ProgressValue}"
                             Maximum="100"
                             Visibility="{Binding ProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Height="8"
                             Margin="0,12,0,0"
                             Foreground="#26A69A"
                             Background="#E0E0E0"
                             BorderThickness="0"/>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             运行日志（高度固定，不随上方内容变化）
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📋 运行日志"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#333"
                           Margin="0,0,0,8"/>

                <Border Grid.Row="1"
                        Background="#FAFAFA"
                        CornerRadius="6"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <ScrollViewer x:Name="LogScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10"
                                  Height="150">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="{Binding Color, Converter={StaticResource StringToColorConverter}}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,3"
                                               FontFamily="Consolas"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
