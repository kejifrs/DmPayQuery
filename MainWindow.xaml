<Window x:Class="DmPayQuery.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DmPayQuery"
        xmlns:models="clr-namespace:DmPayQuery.Models"
        xmlns:converters="clr-namespace:DmPayQuery.Converters"
        mc:Ignorable="d"
        Title="{x:Static local:AppInfo.MainWindowTitle}"
        Icon="pack://application:,,,/DmPayQuery;component/myicon.ico"
        SizeToContent="WidthAndHeight"
        MaxWidth="1200" MaxHeight="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Microsoft YaHei">

    <Window.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DropShadowEffect x:Key="CardShadow"
                         ShadowDepth="2"
                         BlurRadius="8"
                         Opacity="0.2"
                         Color="Gray"/>

        <!-- Tab 标题样式 -->
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,3,0"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="10,10,0,0"
                                BorderThickness="1"
                                BorderBrush="Transparent"
                                Background="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#EEF4FF"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 一体化日期时间容器 -->
        <Style x:Key="DateTimeGroupBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- 容器内无边框 DatePicker -->
        <Style x:Key="InlineDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CalendarStyle">
                <Setter.Value>
                    <Style TargetType="Calendar">
                        <Setter Property="LayoutTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉列表窄滚动条 Thumb -->
        <Style x:Key="SlimScrollThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#E9EFF4" CornerRadius="3" Margin="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉列表窄滚动条 RepeatButton（透明占位） -->
        <Style x:Key="SlimScrollRepeatButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉列表窄滚动条 ScrollBar -->
        <Style x:Key="SlimVerticalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SlimScrollRepeatButton}"
                                              Command="ScrollBar.PageUpCommand"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlimScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SlimScrollRepeatButton}"
                                              Command="ScrollBar.PageDownCommand"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉列表窄滚动条 ScrollViewer -->
        <ControlTemplate x:Key="SlimScrollViewerTemplate" TargetType="ScrollViewer">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ScrollContentPresenter Grid.Column="0"/>
                <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                           Style="{StaticResource SlimVerticalScrollBar}"
                           Value="{TemplateBinding VerticalOffset}"
                           Maximum="{TemplateBinding ScrollableHeight}"
                           ViewportSize="{TemplateBinding ViewportHeight}"
                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
            </Grid>
        </ControlTemplate>

        <!-- 容器内无背景 ComboBox（完全扁平 + 窄滚动条下拉） -->
        <Style x:Key="InlineComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 不可见的 ToggleButton 覆盖整个区域用于打开下拉 -->
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- 选中值显示 -->
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="6,0,14,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <!-- 小箭头 -->
                            <Path x:Name="Arrow"
                                  Data="M 0 0 L 4 4 L 8 0"
                                  Fill="#94A3B8"
                                  Stroke="#94A3B8"
                                  StrokeThickness="1"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,4,0"/>

                            <!-- 下拉弹出框 -->
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="0,4">
                                        <ScrollViewer SnapsToDevicePixels="True"
                                                      Template="{StaticResource SlimScrollViewerTemplate}">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#475569"/>
                                <Setter TargetName="Arrow" Property="Stroke" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="#334155"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#EEF2FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 时间分隔符冒号 -->
        <Style x:Key="TimeSeparator" TargetType="TextBlock">
            <Setter Property="Text" Value=":"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- 日期与时间之间的竖线分隔 -->
        <Style x:Key="DateTimeDivider" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Margin" Value="4,5"/>
        </Style>

        <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <!-- Tab 查询配置区 -->
            <RowDefinition Height="Auto"/>
            <!-- 文件选择 + 操作按钮 + 进度条 -->
            <RowDefinition Height="Auto"/>
            <!-- 运行日志 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             配置区：Tab 切换（消费查询 / 流水开厅实名查询）
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#fafafa"
                CornerRadius="8"
                Padding="20,15"
                Margin="0,0,0,12"
                Effect="{StaticResource CardShadow}">
            <StackPanel>

                <TabControl SelectedIndex="{Binding ActiveTabIndex}"
                            Background="Transparent"
                            BorderThickness="0,0,0,1"
                            BorderBrush="Transparent"
                            Padding="0">

                    <!-- ─── Tab1：消费查询 ─── -->
                    <TabItem Header="💰 消费查询" Style="{StaticResource TabItemStyle}">
                        <StackPanel Margin="0,14,0,0">

                            <!-- 提示文字 -->
                            <TextBlock Text="💡 查询表需包含 [拍走时间] 和 [消费ID] 或 [消费UID]列"
                                       FontSize="12" Foreground="#888" Margin="0,0,0,10"/>

                            <!-- 查询模式 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="🔍︎ 查询模式：" Width="90" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="14"/>
                                <RadioButton Content="ID查充值/送礼"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.IdRechargeOrGift}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="ID只查送礼"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.IdGiftOnly}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="UID查充值/送礼"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.UidRechargeOrGift}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <!-- 拍走时间（开始日期模式） -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <TextBlock Text="🕗︎ 拍走时间：" Width="90" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="14"/>
                                <RadioButton Content="不调整默认"
                                             IsChecked="{Binding DateMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DateMode.Original}}"
                                             Margin="0,0,22,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="拍走时间前1天（防止0点填错）"
                                             IsChecked="{Binding DateMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DateMode.PreviousDay}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <!-- 截止时间策略 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="🕜︎ 截止时间：" Width="90" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="14"/>
                                <RadioButton Content="最新"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Latest}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="7日"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Days7}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="15日"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Days15}}"
                                             Margin="0,0,18,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="30日"
                                             IsChecked="{Binding DeadlineMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:DeadlineMode.Days30}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                        </StackPanel>
                    </TabItem>

                    <!-- ─── Tab2：流水/开厅日期/实名查询 ─── -->
                    <TabItem Header="📊 流水/开厅日期/实名查询" Style="{StaticResource TabItemStyle}">
                        <StackPanel Margin="0,14,0,0">

                            <!-- 提示文字 -->
                            <TextBlock Text="💡 查询表需包含 [厅ID] 或 [主播ID]列"
                                       FontSize="12" Foreground="#888" Margin="0,0,0,10"/>

                            <!-- 查询模式 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="🔍︎ 查询模式：" Width="90" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="14"/>
                                <RadioButton Content="ID查厅流水&amp;开厅时间"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.RoomSerialAndCreateTime}}"
                                             Margin="0,0,22,0" VerticalContentAlignment="Center" FontSize="14"/>
                                <RadioButton Content="ID查主播流水&amp;实名"
                                             IsChecked="{Binding QueryMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:QueryMode.AnchorSerialAndIdCard}}"
                                             VerticalContentAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <!-- 自定义开始时间（一体化） -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <TextBlock Text="🕗︎ 开始时间：" Width="90" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="14"/>
                                <Border Style="{StaticResource DateTimeGroupBorder}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <DatePicker SelectedDate="{Binding CustomStartDate, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="128"
                                                    Style="{StaticResource InlineDatePickerStyle}"/>
                                        <Border Style="{StaticResource DateTimeDivider}"/>
                                        <ComboBox ItemsSource="{Binding HourOptions}"
                                                  SelectedItem="{Binding CustomStartHour, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemStringFormat="{}{0:D2}"
                                                  Width="52"
                                                  Style="{StaticResource InlineComboBoxStyle}"/>
                                        <TextBlock Style="{StaticResource TimeSeparator}"/>
                                        <ComboBox ItemsSource="{Binding MinuteSecondOptions}"
                                                  SelectedItem="{Binding CustomStartMinute, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemStringFormat="{}{0:D2}"
                                                  Width="52"
                                                  Style="{StaticResource InlineComboBoxStyle}"/>
                                        <TextBlock Style="{StaticResource TimeSeparator}"/>
                                        <ComboBox ItemsSource="{Binding MinuteSecondOptions}"
                                                  SelectedItem="{Binding CustomStartSecond, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemStringFormat="{}{0:D2}"
                                                  Width="52"
                                                  Style="{StaticResource InlineComboBoxStyle}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 自定义截止时间（一体化） -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="🕜︎ 截止时间：" Width="90" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="14"/>
                                <Border Style="{StaticResource DateTimeGroupBorder}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <DatePicker SelectedDate="{Binding CustomEndDate, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="128"
                                                    Style="{StaticResource InlineDatePickerStyle}"/>
                                        <Border Style="{StaticResource DateTimeDivider}"/>
                                        <ComboBox ItemsSource="{Binding HourOptions}"
                                                  SelectedItem="{Binding CustomEndHour, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemStringFormat="{}{0:D2}"
                                                  Width="52"
                                                  Style="{StaticResource InlineComboBoxStyle}"/>
                                        <TextBlock Style="{StaticResource TimeSeparator}"/>
                                        <ComboBox ItemsSource="{Binding MinuteSecondOptions}"
                                                  SelectedItem="{Binding CustomEndMinute, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemStringFormat="{}{0:D2}"
                                                  Width="52"
                                                  Style="{StaticResource InlineComboBoxStyle}"/>
                                        <TextBlock Style="{StaticResource TimeSeparator}"/>
                                        <ComboBox ItemsSource="{Binding MinuteSecondOptions}"
                                                  SelectedItem="{Binding CustomEndSecond, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemStringFormat="{}{0:D2}"
                                                  Width="52"
                                                  Style="{StaticResource InlineComboBoxStyle}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </TabItem>

                     <!-- ─── Tab3：更多待加 ─── -->
                     <TabItem Header="🧩 更多" Style="{StaticResource TabItemStyle}">
                         <Grid Margin="0,14,0,0">
                             <TextBlock Text="加点啥呢?"
                                        FontSize="112"
                                        Foreground="#666"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"/>
                         </Grid>
                     </TabItem>

                </TabControl>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             文件选择 + 操作按钮 + 进度条（公共区域）
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#fafafa"
                CornerRadius="8"
                Padding="20,15"
                Margin="0,0,0,12"
                Effect="{StaticResource CardShadow}">
            <StackPanel>

                <!-- 文件选择 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="📄 Excel文件：" Width="108" VerticalAlignment="Center"
                               Foreground="#555" FontSize="14"/>
                    <Button Content="📂 选择文件"
                            Command="{Binding SelectFileCommand}"
                            Width="96" Height="34"
                            Background="White"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            Foreground="Black"
                            FontWeight="Normal"/>
                    <Grid Margin="10,0,0,0">
                        <TextBox x:Name="FilePathTextBox"
                                 Text="{Binding FilePath}"
                                 IsReadOnly="True"
                                 Width="340" Height="34"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 BorderBrush="#DDD"
                                 BorderThickness="1"
                                 Background="#FAFAFA"/>
                        <TextBlock Text="请选择待查询的Excel表"
                                   VerticalAlignment="Center"
                                   Foreground="#999"
                                   Margin="16,0,0,0"
                                   IsHitTestVisible="False"
                                   Opacity="0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=FilePathTextBox}" Value="">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button Content="🚀 一键查询"
                            Command="{Binding StartQueryCommand}"
                            IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBooleanConverter}}"
                            Width="110" Height="40"
                            Background="#1E88E5"
                            Foreground="White"
                            FontSize="14" FontWeight="Normal"
                            BorderThickness="0"
                            Margin="0,10,20,0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#2196f3"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🗑️ 清空日志"
                            Command="{Binding ClearLogsCommand}"
                            Width="110" Height="40"
                            Background="#fafafa"
                            BorderBrush="#1E88E5"
                            BorderThickness="1"
                            Foreground="#1E88E5"
                            FontSize="14" FontWeight="Normal"
                            Margin="0,10,20,0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📊 数据看板"
                            Command="{Binding OpenDashboardCommand}"
                            Width="110" Height="40"
                            Background="#fafafa"
                            BorderBrush="#1E88E5"
                            BorderThickness="1"
                            Foreground="#1E88E5"
                            FontSize="14" FontWeight="Normal"
                            Margin="0,10,20,0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>

                <!-- 进度条 -->
                <ProgressBar Value="{Binding ProgressValue}"
                             Maximum="100"
                             Visibility="{Binding ProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Height="8"
                             Margin="0,12,0,0"
                             Foreground="#26A69A"
                             Background="#E0E0E0"
                             BorderThickness="0"/>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             运行日志（高度固定，不随上方内容变化）
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📋 运行日志"
                           FontSize="14" FontWeight="Medium"
                           Foreground="#333"
                           Margin="0,-8,0,8"/>

                <Border Grid.Row="1"
                        Background="#FAFAFA"
                        CornerRadius="6"
                        BorderBrush="Transparent"
                        BorderThickness="1">
                    <ScrollViewer x:Name="LogScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10"
                                  Height="150"
                                  Template="{StaticResource SlimScrollViewerTemplate}">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="{Binding Color, Converter={StaticResource StringToColorConverter}}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,3"
                                               FontFamily="Consolas"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
